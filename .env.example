# Root directory for all bot state, credentials, session cookie, Chrome profile,
# and drafts. Every script defaults to $HOME/canvas-check when unset.
CANVAS_CHECK_HOME=/home/agent/canvas-check

# Base URL of your institution's Canvas instance (no trailing slash, no /api/v1 —
# the scripts append it). e.g. https://canvas.myuniversity.edu
CANVAS_BASE_URL=https://canvas.instructure.com

# Name used in the assignment-draft LLM prompt so drafts address the right person.
STUDENT_NAME=the student

# Comma-separated keywords that mark an assignment as un-draftable (in-person
# events, attendance, physical hand-ins). Empty = no keyword filter.
# Example: SKIP_KEYWORDS=attend,attendance,in-person,in person,come to class,sign in,ticket,museum,observatory
SKIP_KEYWORDS=

# Where canvas_export.py writes the local coursework mirror (default ~/canvas-export).
CANVAS_EXPORT_DIR=/home/agent/canvas-export

# Interpreter with Playwright installed, used by md_to_pdf.py to render PDFs.
# Defaults to $CANVAS_CHECK_HOME/.venv/bin/python when present, else the current python.
RENDER_PYTHON=/home/agent/canvas-check/.venv/bin/python

# Set to any non-empty value to make auto_login.py dump Duo page HTML for debugging.
# DUO_DEBUG=1

# ---------------------------------------------------------------------------
# Credential FILES (not env vars). All live under $CANVAS_CHECK_HOME, chmod 600.
# None of them may ever be committed — see .gitignore.
#
#   .telegram_creds   sourced by canvas_check.sh; shell format:
#                       TELEGRAM_BOT_TOKEN=123456:dummy-token
#                       TELEGRAM_CHAT_ID=123456789
#   .canvas_creds     read by auto_login.py; shell format:
#                       CANVAS_USER=your_sso_username
#                       CANVAS_PASS=your_password
#   .duo_totp         written by duo_enroll.py; JSON:
#                       {"secret": "<base32 HOTP seed>", "counter": 0}
#   .anthropic_key    sourced by canvas_check.sh for the claude CLI; shell format:
#                       export ANTHROPIC_API_KEY=your-anthropic-api-key
# ---------------------------------------------------------------------------
